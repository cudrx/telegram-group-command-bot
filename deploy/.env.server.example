# Image coordinates
GHCR_IMAGE=ghcr.io/example/test-chatbot
IMAGE_TAG=latest

# Runtime
NODE_ENV=production

# Api Keys
TELEGRAM_BOT_TOKEN=your-telegram-token
LLM_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key
GLADIA_API_KEY=your-api-key
CLOUDFLARE_AI_API_KEY=your-api-key
CLOUDFLARE_ACCOUNT_ID=your-account-id

# LLM / provider
LLM_BASE_URL=https://api.deepseek.com
LLM_REPLY_MODEL=deepseek-chat
LLM_PLANNER_MODEL=deepseek-chat
LOG_LLM_TEXT=false

# Behavior
DESCRIBE_CONTEXT_LIMIT=10
ANSWER_CONTEXT_LIMIT=20
EXPLAIN_CONTEXT_LIMIT=20
DECIDE_CONTEXT_LIMIT=40
SUMMARIZE_CONTEXT_LIMIT=80

# Deploy announcements
DEPLOY_NOTIFY_CHAT_ID=-1002155313986

# Storage and assistant instructions
SQLITE_PATH=/app/data/bot.sqlite
