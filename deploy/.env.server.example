# Image coordinates
GHCR_IMAGE=ghcr.io/example/test-chatbot
IMAGE_TAG=latest

# Runtime
NODE_ENV=production

# Telegram
TELEGRAM_BOT_TOKEN=replace-me

# LLM / provider
LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.deepseek.com
LLM_REPLY_MODEL=deepseek-chat
LLM_REPLY_TEMPERATURE=0.6
LLM_TIMEOUT_MS=45000
LLM_MAX_RETRIES=2
LOG_LLM_TEXT=false
LOG_LEVEL=info
LOG_COLOR=true

# Behavior
EXPLAIN_CONTEXT_LIMIT=16
SUMMARIZE_CONTEXT_LIMIT=128
DECIDE_CONTEXT_LIMIT=64
REPLY_MIN_TYPING_MS=900
REPLY_MAX_TYPING_MS=2200
REPLY_TYPING_REFRESH_MS=4000

# Storage and assistant instructions
SQLITE_PATH=/app/data/bot.sqlite
ASSISTANT_INSTRUCTIONS_FILE=config/assistant-instructions.md
