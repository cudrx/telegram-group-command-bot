{
  "name": "test-chatbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "migrate": "node --import tsx scripts/migrate.ts",
    "deploy:metadata": "tsx scripts/generate-deploy-metadata.ts",
    "eval:intents": "npm run build && node dist/scripts/evaluate-intents.js",
    "eval:intents:one": "npm run build && node dist/scripts/evaluate-intents.js",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.38.3",
    "openai": "^6.33.0",
    "zod": "^3.25.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
