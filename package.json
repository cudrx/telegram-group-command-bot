{
  "name": "telegram-group-command-bot",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "migrate": "node --import tsx scripts/migrate.ts",
    "deploy:metadata": "tsx scripts/generate-deploy-metadata.ts",
    "eval:intents": "npm run build && node dist/scripts/evaluate-intents.js",
    "eval:intents:one": "npm run build && node dist/scripts/evaluate-intents.js",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "dotenv": "^17.4.2",
    "grammy": "^1.44.0",
    "openai": "^6.42.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
