# Runtime
NODE_ENV=development

# API keys
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
LLM_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key

# Media analysis
MEDIA_ANALYSIS_ENABLED=false
DESCRIBE_CONTEXT_LIMIT=10
STT_PROVIDER=gladia
GLADIA_API_KEY=your-gladia-api-key
VISION_PROVIDER=cloudflare
CLOUDFLARE_AI_API_KEY=your-cloudflare-ai-api-key
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
MEDIA_MAX_FILE_BYTES=10000000
MEDIA_ARTIFACT_RETENTION_DAYS=7
MESSAGE_RETENTION_DAYS=7
DATABASE_CLEANUP_INTERVAL_HOURS=24

# LLM / provider
LLM_BASE_URL=https://api.deepseek.com
LLM_REPLY_MODEL=deepseek-chat
LLM_PLANNER_MODEL=deepseek-chat
LLM_REPLY_TEMPERATURE=0.6
LLM_REPLY_ENABLE_THINKING=false
LLM_TIMEOUT_MS=25000
LLM_MAX_RETRIES=1
LOG_LLM_TEXT=false
LOG_LEVEL=info
LOG_COLOR=true

# Behavior
EXPLAIN_CONTEXT_LIMIT=16
SUMMARIZE_CONTEXT_LIMIT=128
DECIDE_CONTEXT_LIMIT=64
REPLY_MIN_TYPING_MS=900
REPLY_MAX_TYPING_MS=2200
REPLY_TYPING_REFRESH_MS=4000

# Deploy announcements
DEPLOY_NOTIFY_CHAT_ID=-1002155313986

# Lookup / web grounding
LOOKUP_ENABLED=false
LOOKUP_PROVIDER=tavily
LOOKUP_TIMEOUT_MS=7000
LOOKUP_MAX_QUERIES=1
LOOKUP_MAX_RESULTS=3

# Storage
SQLITE_PATH=data/bot.sqlite
