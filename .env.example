# Runtime
NODE_ENV=development

# API keys
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
LLM_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key
GLADIA_API_KEY=your-gladia-api-key
OCR_SPACE_API_KEY=your-ocr-space-api-key
CLOUDFLARE_AI_API_KEY=your-cloudflare-ai-api-key
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
YANDEX_SPEECHKIT_API_KEY=your-yandex-speechkit-api-key

# LLM / provider
LLM_BASE_URL=https://api.deepseek.com
LLM_REPLY_MODEL=deepseek-v4-flash
LLM_PLANNER_MODEL=deepseek-v4-flash
LOG_LLM_TEXT=false

# Behavior
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_ADMIN_ID=your-telegram-admin-id
TELEGRAM_LINK_USER_IDS=
ANSWER_CONTEXT_LIMIT=20
DECIDE_CONTEXT_LIMIT=40
SUMMARIZE_CONTEXT_LIMIT=80

# Storage
SQLITE_PATH=data/bot.sqlite
REDDIT_COOKIES_PATH=data/reddit-cookies.txt
INSTAGRAM_COOKIES_PATH=data/instagram-cookies.txt
YOUTUBE_COOKIES_PATH=data/youtube-cookies.txt
