# Runtime
NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
LLM_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key

# LLM / provider
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_REPLY_MODEL=qwen3.6-plus
LLM_FAST_REPLY_MODEL=qwen3.6-flash
LLM_PLANNER_MODEL=qwen3.6-flash
LLM_REPLY_TEMPERATURE=0.6
LLM_REPLY_ENABLE_THINKING=false
LLM_TIMEOUT_MS=25000
LLM_MAX_RETRIES=1
LOG_LLM_TEXT=false
LOG_LEVEL=info
LOG_COLOR=true

# Behavior
EXPLAIN_CONTEXT_LIMIT=16
SUMMARIZE_CONTEXT_LIMIT=128
DECIDE_CONTEXT_LIMIT=64
REPLY_MIN_TYPING_MS=900
REPLY_MAX_TYPING_MS=2200
REPLY_TYPING_REFRESH_MS=4000

# Lookup / web grounding
LOOKUP_ENABLED=false
LOOKUP_PROVIDER=tavily
LOOKUP_TIMEOUT_MS=7000
LOOKUP_MAX_QUERIES=1
LOOKUP_MAX_RESULTS=3

# Storage and assistant instructions
SQLITE_PATH=data/bot.sqlite
ASSISTANT_INSTRUCTIONS_FILE=config/assistant-instructions.md
